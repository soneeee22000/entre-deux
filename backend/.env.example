# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://entredeux:entredeux_dev@127.0.0.1:5433/entredeux
DATABASE_URL_SYNC=postgresql://entredeux:entredeux_dev@127.0.0.1:5433/entredeux

# App
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173
AUDIT_ENABLED=true

# Auth (optional: bearer token for API auth, leave empty to skip in dev)
DEMO_API_TOKEN=

# JWT Auth (set JWT_SECRET_KEY to enable JWT auth)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
